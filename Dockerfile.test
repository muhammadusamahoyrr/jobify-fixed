# ───────────────────────────────────────────────────────────────
# Dockerfile.test — Python + Chromium + Selenium (CI Stable)
# ───────────────────────────────────────────────────────────────

FROM python:3.11-slim

# ── Install system dependencies + Chromium browser ─────────────
RUN apt-get update && apt-get install -y \
    chromium \
    chromium-driver \
    wget \
    curl \
    gnupg \
    unzip \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    libgtk-3-0 \
    libgbm1 \
    libxshmfence1 \
    libu2f-udev \
 && rm -rf /var/lib/apt/lists/*

# ── Set working directory ───────────────────────────────────────
WORKDIR /tests

# ── Install Python dependencies ─────────────────────────────────
RUN pip install --no-cache-dir \
    selenium==4.18.1 \
    requests==2.31.0 \
    pytest==8.1.1

# ── Copy test files ──────────────────────────────────────────────
COPY test_job_portal.py .

# ── Optional: quick Chromium + Selenium sanity check ────────────
RUN python -c "\
from selenium import webdriver; \
from selenium.webdriver.chrome.options import Options; \
opts = Options(); \
opts.add_argument('--headless'); \
opts.add_argument('--no-sandbox'); \
opts.add_argument('--disable-dev-shm-usage'); \
driver = webdriver.Chrome(options=opts); \
driver.quit()" || true

# ── Create results directory for Jenkins ────────────────────────
RUN mkdir -p /tests/results

# ── Default command: run tests with JUnit output ────────────────
CMD ["python", "-m", "pytest", "test_job_portal.py", \
     "-v", "--tb=short", \
     "--junit-xml=/tests/results/test-results.xml"]
